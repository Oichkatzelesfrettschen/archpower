# Maintainer: Alexander Baldeck <alex.bldck@gmail.com>

_target=mips64el-unknown-linux-gnu
pkgname=${_target}-gcc-stage1
pkgver=14.2.1+r753+g1cd744a6828f
_commit=1cd744a6828f6ab9179906d16434ea40b6404737
pkgrel=1
pkgdesc="The GNU Compiler Collection - C and C++ frontends (${_target}) stage1"
arch=(x86_64 powerpc64le powerpc64 powerpc)
license=(GPL LGPL FDL custom)
url='http://gcc.gnu.org'
depends=("${_target}-binutils>=2.42" "${_target}-linux-api-headers>=6.8" libmpc elfutils zlib)
makedepends=(git)
options=(!emptydirs !debug !distcc !lto !strip)
conflicts=("${_target}-gcc-stage2" "${_target}-gcc")
provides=("${_target}-gcc=${pkgver}")
source=(git+https://sourceware.org/git/gcc.git#commit=${_commit}
        gcc11-Wno-format-security.patch)
validpgpkeys=(F3691687D867B81B51CE07D9BBE43771487328A9
              86CFFCA918CF3AF47147588051E8B148A9999C34
              13975A70E63C361C73AE69EF6EEB81F8981C74C7
              D3A93CAD751C2AF4F8C7AD516C35B99309B5FA62)
sha256sums=('33378643f1c72686181f9d3fcd09caf9b06815324467f5dc9b9a3ea41cfba4b4'
            '504e4b5a08eb25b6c35f19fdbe0c743ae4e9015d0af4759e74150006c283585e')

pkgver() {
  cd gcc
  echo "$(cat gcc/BASE-VER)+$(git describe --abbrev=12 --tags | sed 's/[^-]*-[^-]*-//;s/[^-]*-/r&/;s/-/+/g;s/_/./')"
}

prepare() {
  [[ ! -d gcc ]] && ln -s gcc-${pkgver/+/-} gcc
  cd gcc

  sed -i 's@\./fixinc\.sh@-c true@' gcc/Makefile.in
  sed -i "/ac_cpp=/s/\$CPPFLAGS/\$CPPFLAGS -O2/" {libiberty,gcc}/configure

  patch -Np0 < "$srcdir/gcc11-Wno-format-security.patch"

  mkdir -p "$srcdir/gcc-build"
}

build() {
  cd gcc-build

  CFLAGS=${CFLAGS/-pipe}
  CFLAGS=${CFLAGS/-Wformat -Werror=format-security/}
  CXXFLAGS=${CXXFLAGS/-pipe/}
  CXXFLAGS=${CXXFLAGS/ -Wformat -Werror=format-security/}

  "$srcdir/gcc/configure" --prefix=/usr \
      --program-prefix=${_target}- \
      --with-local-prefix=/usr/${_target} \
      --with-sysroot=/usr/${_target} \
      --with-build-sysroot=/usr/${_target} \
      --with-as=/usr/bin/${_target}-as \
      --with-ld=/usr/bin/${_target}-ld \
      --libdir=/usr/lib --libexecdir=/usr/lib \
      --disable-nls \
      --with-newlib \
      --without-headers \
      --enable-languages=c,c++ \
      --disable-shared \
      --disable-threads \
      --with-system-zlib \
      --enable-tls \
      --disable-libmudflap \
      --disable-libssp \
      --disable-libquadmath \
      --disable-libgomp \
      --disable-libatomic \
      --disable-nls \
      --disable-multilib \
      --disable-werror \
      --enable-checking=release \
      --target=${_target} \
      --host=${CHOST} \
      --build=${CHOST}

  make all-gcc all-target-libgcc
}

package() {
  cd gcc-build

  make DESTDIR="$pkgdir" install-gcc install-target-libgcc

  rm -rf "$pkgdir/usr/share"

  strip "$pkgdir/usr/bin/"* 2>/dev/null || true
  find "$pkgdir/usr/lib" -type f -name "*.o" -exec /usr/bin/${_target}-strip \
    --strip-unneeded {} \; 2>/dev/null || true
}
