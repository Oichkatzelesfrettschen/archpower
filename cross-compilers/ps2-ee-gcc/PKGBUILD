# Maintainer: Alexander Baldeck <alex.bldck@gmail.com>

_target=mips64r5900el-ps2-elf
_target_alias=ee
pkgname=ps2-ee-gcc
pkgver=15.2.0
pkgrel=1
pkgdesc='The GNU Compiler Collection for PlayStation 2 Emotion Engine (R5900)'
arch=(x86_64 powerpc64le powerpc64 powerpc)
url='https://github.com/ps2dev/gcc'
license=(GPL LGPL FDL)
depends=(ps2-ee-binutils libmpc zlib)
makedepends=(git ps2-ee-newlib)
options=(!emptydirs !debug !strip)
source=(git+https://github.com/ps2dev/gcc.git)
sha256sums=('SKIP')

pkgver() {
  cd gcc
  cat gcc/BASE-VER | head -1
}

prepare() {
  cd gcc
  mkdir -p "$srcdir/gcc-build"
}

build() {
  cd gcc-build

  CFLAGS=${CFLAGS/-pipe}
  CFLAGS=${CFLAGS/-Wformat -Werror=format-security/}
  CXXFLAGS=${CXXFLAGS/-pipe/}
  CXXFLAGS=${CXXFLAGS/ -Wformat -Werror=format-security/}

  CFLAGS_FOR_TARGET="-O2 -gdwarf-2 -gz"

  "$srcdir/gcc/configure" \
      --prefix=/usr/ps2dev/${_target_alias} \
      --target=${_target} \
      --with-sysroot=/usr/ps2dev/${_target_alias}/${_target} \
      --enable-languages=c,c++ \
      --with-float=hard \
      --with-newlib \
      --disable-libssp \
      --disable-libgomp \
      --disable-libmudflap \
      --disable-libquadmath \
      --disable-libatomic \
      --disable-nls \
      --disable-shared \
      --disable-threads \
      --disable-multilib \
      --disable-werror \
      --disable-tls \
      --enable-checking=release

  make
}

package() {
  cd gcc-build

  make DESTDIR="$pkgdir" install

  # Remove info and man pages that conflict with host
  rm -rf "$pkgdir/usr/ps2dev/${_target_alias}/share/info"
  rm -rf "$pkgdir/usr/ps2dev/${_target_alias}/share/man/man7"

  # Strip binaries
  strip "$pkgdir/usr/ps2dev/${_target_alias}/bin/"* 2>/dev/null || true
  find "$pkgdir/usr/ps2dev/${_target_alias}/lib" -type f -name "*.a" -exec \
    /usr/ps2dev/${_target_alias}/bin/${_target}-strip --strip-debug {} \; 2>/dev/null || true
}
